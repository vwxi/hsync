// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "adapter": "CodeLLDB",
    "label": "cargo run -p hsync-server",
    "build": {
      "label": "cargo run -p hsync-server",
      "command": "cargo",
      "args": ["run", "--", "--cert", "cert.pem", "--key", "key.pem"],
      "env": {
        "RUSTC_TOOLCHAIN": "/home/v/.rustup/toolchains/stable-x86_64-unknown-linux-gnu",
      },
      "cwd": "/home/v/code/hsync",
      "use_new_terminal": false,
      "allow_concurrent_runs": false,
      "reveal": "always",
      "reveal_target": "dock",
      "hide": "never",
      "tags": [],
      "shell": "system",
      "show_summary": false,
      "show_command": false,
    },
    "sourceLanguages": ["rust"],
  },
]
